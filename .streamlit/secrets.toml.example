# Streamlit Secrets 範本 (Streamlit Cloud 用)
#
# 部署到 Streamlit Cloud 的步驟:
#   1) 進到 app 的 Settings → Secrets 頁
#   2) 把以下內容複製貼上 (TOML 格式)
#   3) 點 Save
#
# 注意:
#   - keys 與本機 .env 一致 (FINMIND_TOKEN, TELEGRAM_BOT_TOKEN ...)
#   - 不要把實際填好的 secrets.toml commit 進 git (.gitignore 已排除)
#   - 留空字串 = 走「無 token / 未設定」模式 (功能不會炸)

# FinMind API Token (留空 = 無 token 模式,有頻率限制)
# 申請: https://finmindtrade.com/
FINMIND_TOKEN = ""

# Telegram Bot (選填,推播用)
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""

# 資料庫位置 (雲端容器內的相對路徑;留預設即可)
DATABASE_PATH = "data/cache.db"

# 預設市場 (TW=台股, US=美股)
DEFAULT_MARKET = "TW"
