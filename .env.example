# 複製此檔為 .env 並填入實際值
# .env 已加入 .gitignore,不會被提交

# FinMind API Token(必填)
# 申請:https://finmindtrade.com/
FINMIND_TOKEN=your_finmind_token_here

# Telegram Bot(選填,用於每日推播)
# 建立 Bot:https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook(選填,Telegram 備援推播)
# 在 Discord 頻道設定 → 整合 → Webhooks → New Webhook → 複製 URL
DISCORD_WEBHOOK_URL=

# 資料庫位置(預設值即可)
DATABASE_PATH=data/cache.db

# 預設市場(TW=台股, US=美股)
DEFAULT_MARKET=TW
