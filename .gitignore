# 環境變數
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.ruff_cache/

# 資料庫
data/*.db
data/*.sqlite

# 大型 snapshot 走 GH Release(2026-05-17,根治 100MB git push 上限)
# parquet 從 GH Release CDN 拉,不入 git;.snapshot_releases.json 是 manifest,要入 git
data/twse_snapshot/*.parquet
data/twse_snapshot/*.parquet.partial

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Streamlit
.streamlit/secrets.toml

# 暫存檔
*.log
*.tmp

# Runtime log 持久化:cron / CLI 腳本透過 src.logging_setup 寫進 logs/{date}-{script}.log
# 不入 repo,本機由 scripts/cleanup_artifacts.py 統一清(預設 7 天)
logs/

# ML 模型備份(M2 v1 -> v3 retrain 留下的本地 safety net,不入 repo)
models/**/*.v1.bak
models/**/*.v2.bak
models/**/*.pre_retrain.bak
models/**/*.v3.candidate
models/baseline_v1.json
models/new_v3.json
